<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Node.js SSR Shopping List</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; display: flex; justify-content: center; padding-top: 50px; }
        .container { width: 400px; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { text-align: center; }
        form { display: flex; gap: 10px; margin-bottom: 20px; }
        input[type="text"] { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 4px; }
        button { padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer; }
        .add-btn { background-color: #28a745; color: white; }
        .delete-btn { background-color: #dc3545; color: white; padding: 5px 10px; font-size: 12px; }
        ul { list-style: none; padding: 0; }
        li { display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #eee; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Shopping List</h1>
        
        <!-- 新增項目的表單：傳送到 /add -->
        <form action="/add" method="POST">
            <input type="text" name="newItem" placeholder="Enter item" required>
            <button type="submit" class="add-btn">Add</button>
        </form>

        <ul>
            <!-- 使用 EJS 迴圈渲染 items 陣列 -->
            <% items.forEach((item, index) => { %>
                <li>
                    <span><%= item %></span>
                    <!-- 刪除項目的表單：傳送到 /delete -->
                    <form action="/delete" method="POST" style="margin: 0;">
                        <input type="hidden" name="index" value="<%= index %>">
                        <button type="submit" class="delete-btn">Delete</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    </div>
</body>
</html>
